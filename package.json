{
  "name": "react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-react-arborist.js",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-test-config": "node scripts/build-test-config.js",
    "depgraph": "depcruise --include-only \"^src/(config|hooks|pages|routes|store|utils)\" --do-not-follow \"^src/(components|providers|services)\" --output-type dot src | dot -T svg | depcruise-wrap-stream-in-html > depgraph.html",
    "depgraph-html": "depcruise --include-only \"^src/(config|hooks|pages|routes|store|utils)\" --do-not-follow \"^src/(components|providers|services)\" --output-type html src > depgraph_html.html",
    "depgraph-report": "depcruise --include-only \"^src/(config|hooks|pages|routes|store|utils)\" --do-not-follow \"^src/(components|providers|services)\" --output-type err-html src > depgraph_report.html",
    "depgraph-err": "depcruise --include-only \"^src/(config|hooks|pages|routes|store|utils)\" --do-not-follow \"^src/(components|providers|services)\"",
    "depgraph-v": "depcruise --include-only \"^src/utils/validation\" --output-type dot src | dot -T svg | depcruise-wrap-stream-in-html > depgraph_v.html"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.27.0",
    "@emotion/react": "^11.14.0",
    "@monaco-editor/react": "^4.7.0",
    "@robloche/chartjs-plugin-streaming": "^3.1.0",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-virtual": "^3.13.12",
    "axios": "^1.10.0",
    "chart.js": "^4.4.7",
    "chartjs-adapter-luxon": "^1.3.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "debounce": "^2.2.0",
    "json-canonicalize": "^2.0.0",
    "json-logic-js": "^2.0.5",
    "luaparse": "^0.3.1",
    "luxon": "^3.7.2",
    "mqtt": "^5.14.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-arborist": "^3.4.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^7.5.0",
    "react-dnd": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^7.0.2",
    "react-virtualized": "^9.22.6",
    "use-stick-to-bottom": "^1.1.1",
    "xmlbuilder": "^15.1.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@redux-devtools/extension": "^3.3.0",
    "@tanstack/eslint-plugin-query": "^5.83.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dependency-cruiser": "^16.10.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-sonarjs": "^3.0.4",
    "globals": "^15.12.0",
    "msw": "^2.10.5",
    "rollup-plugin-visualizer": "^6.0.3",
    "use-resize-observer": "^9.1.0",
    "vite": "^6.0.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
